<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    android:layout_marginBottom="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/txtTenPhongItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="P.101"
                android:textColor="#0066B2"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtTrangThaiItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:background="#E8F8F5"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="TRỐNG"
                android:textColor="#2ECC71"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/txtGhiChuItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Mô tả phòng"
            android:textColor="#333333"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtGiaThueItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💵 0.0tr/tháng"
                android:textColor="#6C757D"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtDienTichItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="24dp"
                android:text="📐 0m²"
                android:textColor="#6C757D"
                android:textSize="14sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/imgHinhAnhItem"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="12dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"
            android:contentDescription="Ảnh phòng" />

    </LinearLayout>
</androidx.cardview.widget.CardView>