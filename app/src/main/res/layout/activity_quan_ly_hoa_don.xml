<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8F9FA">

        <!-- Toolbar -->
        <RelativeLayout
            android:id="@+id/layoutToolbar"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="#FFFFFF"
            android:paddingTop="35dp"
            android:paddingHorizontal="16dp">
            <ImageView
                android:id="@+id/imgMenu"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="#0066B2"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Quản Lý Hóa Đơn"
                android:textColor="#0066B2"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </RelativeLayout>

        <!-- Filter -->
        <LinearLayout
            android:id="@+id/layoutFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/layoutToolbar"
            android:padding="16dp"
            android:orientation="horizontal">
            <Button android:id="@+id/btnFilterTatCa" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="Tất cả" android:textAllCaps="false" android:backgroundTint="#2ECC71"/>
            <Button android:id="@+id/btnFilterNo" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1.2" android:layout_marginStart="8dp" android:text="Chưa thanh toán" android:textAllCaps="false" android:backgroundTint="#E5E5E5" android:textColor="#333333"/>
        </LinearLayout>

        <!-- List -->
        <ListView
            android:id="@+id/lvHoaDon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/layoutFilter"
            android:layout_marginHorizontal="16dp"
            android:divider="@android:color/transparent"
            android:dividerHeight="10dp"/>

        <!-- FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabThemHoaDon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="24dp"
            android:src="@android:drawable/ic_input_add"
            app:backgroundTint="#0066B2"
            app:tint="@android:color/white"/>

        <!-- Form (Hidden by default) -->
        <LinearLayout
            android:id="@+id/layoutFormHoaDon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_margin="20dp"
            android:background="@android:color/white"
            android:elevation="32dp"
            android:orientation="vertical"
            android:visibility="gone">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:paddingHorizontal="16dp"
                android:background="#F8F9FA">
                <TextView
                    android:id="@+id/txtTieuDeForm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Lập hóa đơn mới"
                    android:textColor="#0066B2"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                <ImageView
                    android:id="@+id/imgDongForm"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"/>
            </RelativeLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chọn phòng"/>
                    <Spinner android:id="@+id/spnPhongHd" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tháng (MM/YYYY)"/>
                    <EditText android:id="@+id/edtThangHd" android:layout_width="match_parent" android:layout_height="48dp" android:hint="Vd: 03/2024" android:layout_marginBottom="12dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:weightSum="2">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Số điện mới"/>
                            <EditText android:id="@+id/edtDienMoi" android:layout_width="match_parent" android:layout_height="48dp" android:inputType="number"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="4dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Số nước mới"/>
                            <EditText android:id="@+id/edtNuocMoi" android:layout_width="match_parent" android:layout_height="48dp" android:inputType="number"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dịch vụ khác" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    <LinearLayout android:id="@+id/layoutDichVuCheckboxes" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="12dp"/>

                    <TextView android:id="@+id/txtXemTruocTong" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Dự kiến tổng tiền: 0 VNĐ" android:textColor="#D32F2F" android:textStyle="bold" android:textSize="16sp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:gravity="end">
                        <Button android:id="@+id/btnHuyHd" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hủy" android:layout_marginEnd="8dp"/>
                        <Button android:id="@+id/btnLuuHd" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lưu hóa đơn" android:backgroundTint="#0066B2" android:textColor="@android:color/white"/>
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </RelativeLayout>

    <include layout="@layout/toolbar_va_menu"/>

</androidx.drawerlayout.widget.DrawerLayout>
