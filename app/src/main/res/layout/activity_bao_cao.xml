<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8F9FB">

        <!-- Toolbar Header -->
        <RelativeLayout
            android:id="@+id/layoutToolbar"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="#FFFFFF"
            android:paddingHorizontal="16dp"
            android:elevation="4dp">
            <ImageView
                android:id="@+id/imgMenu"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="15dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="#0066B2"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/imgMenu"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="15dp"
                android:layout_marginStart="16dp"
                android:text="Trang chủ"
                android:textColor="#0066B2"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="12dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="#0066B2"/>
        </RelativeLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/layoutToolbar"
            android:clipToPadding="false"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Welcome Section -->
                <TextView
                    android:id="@+id/txtWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xin chào, Admin"
                    android:textColor="#333333"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/txtSubWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đây là thống kê của trang"
                    android:textColor="#666666"
                    android:layout_marginTop="4dp"
                    android:textSize="14sp"/>

                <!-- Doanh thu Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Thống kê doanh thu"
                                android:textStyle="bold"
                                android:textColor="#333333"
                                android:textSize="16sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="6 tháng gần nhất"
                                android:textColor="#666666"
                                android:textSize="13sp"/>
                        </RelativeLayout>

                        <!-- Giả lập biểu đồ cột đơn giản -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:layout_marginTop="30dp"
                            android:gravity="bottom"
                            android:orientation="horizontal"
                            android:weightSum="6">
                            <View android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:background="#F0F2F5" android:layout_margin="4dp"/>
                            <View android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1" android:background="#F0F2F5" android:layout_margin="4dp"/>
                            <View android:layout_width="0dp" android:layout_height="30dp" android:layout_weight="1" android:background="#F0F2F5" android:layout_margin="4dp"/>
                            <View android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1" android:background="#F0F2F5" android:layout_margin="4dp"/>
                            <View android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:background="#F0F2F5" android:layout_margin="4dp"/>
                            <View android:layout_width="0dp" android:layout_height="100dp" android:layout_weight="1" android:background="#0066B2" android:layout_margin="4dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="6">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T10" android:gravity="center" android:textSize="10sp"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T11" android:gravity="center" android:textSize="10sp"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T12" android:gravity="center" android:textSize="10sp"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T1" android:gravity="center" android:textSize="10sp"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T2" android:gravity="center" android:textSize="10sp"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T3" android:gravity="center" android:textStyle="bold" android:textColor="#0066B2" android:textSize="10sp"/>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginVertical="16dp"/>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:id="@+id/txtLabelThangNay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tổng doanh thu tháng này"
                                android:textColor="#666666"
                                android:textSize="14sp"/>
                            <TextView
                                android:id="@+id/txtDoanhThuThangNay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_below="@id/txtLabelThangNay"
                                android:text="******đ"
                                android:textColor="#0066B2"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:text="📈 +12%"
                                android:textColor="#2ECC71"
                                android:textStyle="bold"/>
                        </RelativeLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Row 2: Occupancy and Quick Stats -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:weightSum="2">

                    <!-- Tỉ lệ lấp đầy Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tỉ lệ lấp đầy"
                                android:textStyle="bold"
                                android:textColor="#333333"
                                android:textSize="15sp"/>

                            <RelativeLayout
                                android:layout_width="100dp"
                                android:layout_height="100dp"
                                android:layout_gravity="center"
                                android:layout_marginTop="16dp">
                                <ProgressBar
                                    android:id="@+id/progressOccupancy"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:indeterminate="false"
                                    android:max="100"
                                    android:progress="79"
                                    android:progressDrawable="@drawable/circular_progress" />
                                <TextView
                                    android:id="@+id/txtPercentOccupancy"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_centerInParent="true"
                                    android:text="79%"
                                    android:textColor="#333333"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />
                            </RelativeLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginTop="16dp">
                                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center_vertical">
                                    <View android:layout_width="8dp" android:layout_height="8dp" android:background="#2ECC71"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" Đã thuê" android:textSize="10sp" android:textColor="#666666"/>
                                </LinearLayout>
                                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginTop="4dp">
                                    <View android:layout_width="8dp" android:layout_height="8dp" android:background="#A9DFBF"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" Phòng trống" android:textSize="10sp" android:textColor="#666666"/>
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Grid Quick Stats -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.9"
                        android:orientation="vertical">

                        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cardPhong"
                                android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginBottom="4dp" app:cardCornerRadius="12dp" app:cardElevation="2dp" app:strokeWidth="0dp">
                                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="8dp">
                                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_myplaces" app:tint="#0066B2"/>
                                    <TextView android:id="@+id/txtCountPhong" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="24" android:textStyle="bold" android:textSize="16sp"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Phòng" android:textSize="11sp" android:textColor="#666666"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cardKhach"
                                android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="8dp" android:layout_marginBottom="4dp" app:cardCornerRadius="12dp" app:cardElevation="2dp" app:strokeWidth="0dp">
                                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="8dp">
                                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_myplaces" app:tint="#0066B2"/>
                                    <TextView android:id="@+id/txtCountKhach" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="42" android:textStyle="bold" android:textSize="16sp"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Khách" android:textSize="11sp" android:textColor="#666666"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:layout_marginTop="8dp">
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cardHopDong"
                                android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" app:cardCornerRadius="12dp" app:cardElevation="2dp" app:strokeWidth="0dp">
                                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="8dp">
                                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_agenda" app:tint="#0066B2"/>
                                    <TextView android:id="@+id/txtCountHopDong" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="38" android:textStyle="bold" android:textSize="16sp"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hợp đồng" android:textSize="11sp" android:textColor="#666666"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cardHoaDon"
                                android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="8dp" app:cardCornerRadius="12dp" app:cardElevation="2dp" app:strokeWidth="0dp">
                                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="8dp">
                                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_agenda" app:tint="#0066B2"/>
                                    <TextView android:id="@+id/txtCountHoaDon" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15" android:textStyle="bold" android:textSize="16sp"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hóa đơn" android:textSize="11sp" android:textColor="#666666"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Unpaid Invoices Footer Summary -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardUnpaidSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    android:backgroundTint="#FDEDEC"
                    app:strokeWidth="0dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp">
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/iconUnpaid"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            app:cardCornerRadius="8dp"
                            android:backgroundTint="#E74C3C"
                            app:cardElevation="0dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_agenda"
                                app:tint="#FFFFFF"/>
                        </com.google.android.material.card.MaterialCardView>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/iconUnpaid"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical"
                            android:layout_centerVertical="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hóa đơn chưa thanh toán"
                                android:textColor="#C0392B"
                                android:textStyle="bold"
                                android:textSize="14sp"/>
                            <TextView
                                android:id="@+id/txtUnpaidSummary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="8.500.000đ (3 phiếu)"
                                android:textColor="#E74C3C"
                                android:textSize="13sp"/>
                        </LinearLayout>
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@android:drawable/ic_media_play"
                            app:tint="#E74C3C"/>
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </ScrollView>
    </RelativeLayout>

    <include layout="@layout/toolbar_va_menu"/>

</androidx.drawerlayout.widget.DrawerLayout>
