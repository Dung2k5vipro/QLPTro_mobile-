<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    android:background="#F8F9FA">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <RelativeLayout
            android:id="@+id/layoutToolbar"
            android:layout_width="match_parent"
            android:layout_height="155dp"
            android:background="@android:color/white"
            android:paddingTop="45dp"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/imgMenu"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:contentDescription="Menu"
                app:tint="#0066B2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_centerVertical="true"
                android:text="Quản Lý Khách Thuê"
                android:textColor="#0066B2"
                android:textSize="22sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/layoutHeaderAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/layoutToolbar"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="Quản lý khách\nthuê"
                android:textColor="#111111"
                android:textSize="24sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/btnThemKhachNhanh"
                android:layout_width="200dp"
                android:layout_height="64dp"
                android:layout_alignParentEnd="true"
                android:background="@android:drawable/toast_frame"
                android:backgroundTint="#2196F3"
                android:gravity="center"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_add"
                    app:tint="@android:color/white"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Thêm khách\nthuê"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/layoutSearch"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_below="@id/layoutHeaderAction"
            android:layout_margin="16dp"
            android:background="@android:drawable/editbox_background_normal"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="#6C757D" />
            <EditText
                android:id="@+id/edtTimKiemKhach"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:background="@android:color/transparent"
                android:hint="Tìm theo họ tên, số điện thoại hoặc C..."
                android:inputType="textNoSuggestions"
                android:importantForAutofill="no"
                android:textSize="15sp" />
        </LinearLayout>

        <ListView
            android:id="@+id/lvKhachThue"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/layoutSearch"
            android:layout_alignParentBottom="true"
            android:layout_marginHorizontal="16dp"
            android:divider="@android:color/transparent"
            android:dividerHeight="4dp" />

        <LinearLayout
            android:id="@+id/layoutFormKhach"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_margin="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:elevation="32dp"
            android:orientation="vertical"
            android:visibility="gone">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:paddingHorizontal="16dp"
                android:background="#F8F9FA">
                <TextView
                    android:id="@+id/txtTieuDeFormKhach"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Thông tin khách thuê"
                    android:textColor="#0066B2"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <ImageView
                    android:id="@+id/imgDongFormKhach"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="#333333"
                    android:clickable="true"
                    android:focusable="true"/>
            </RelativeLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Họ tên" android:textColor="#555555" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <EditText android:id="@+id/edtFormHoTen" android:layout_width="match_parent" android:layout_height="48dp" android:background="@android:drawable/editbox_background_normal" android:paddingHorizontal="12dp" android:inputType="textNoSuggestions|textCapWords" android:importantForAutofill="no" android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="12dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Số điện thoại" android:textColor="#555555" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                            <EditText android:id="@+id/edtFormSdt" android:layout_width="match_parent" android:layout_height="48dp" android:background="@android:drawable/editbox_background_normal" android:paddingHorizontal="12dp" android:inputType="phone" android:importantForAutofill="no"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CCCD" android:textColor="#555555" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                            <EditText android:id="@+id/edtFormCccd" android:layout_width="match_parent" android:layout_height="48dp" android:background="@android:drawable/editbox_background_normal" android:paddingHorizontal="12dp" android:inputType="number" android:importantForAutofill="no"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Địa chỉ" android:textColor="#555555" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <EditText android:id="@+id/edtFormDiaChi" android:layout_width="match_parent" android:layout_height="64dp" android:gravity="top|start" android:background="@android:drawable/editbox_background_normal" android:padding="12dp" android:inputType="textNoSuggestions|textMultiLine" android:importantForAutofill="no" android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="24dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Giới tính" android:textColor="#555555" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                            <Spinner android:id="@+id/spFormGioiTinh" android:layout_width="match_parent" android:layout_height="48dp" android:background="@android:drawable/btn_dropdown"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ngày sinh" android:textColor="#555555" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                            <EditText android:id="@+id/edtFormNgaySinh" android:layout_width="match_parent" android:layout_height="48dp" android:background="@android:drawable/editbox_background_normal" android:paddingHorizontal="12dp" android:hint="DD/MM/YYYY" android:focusable="false" android:clickable="true" android:importantForAutofill="no"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtLabelAnhCccd"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ảnh CCCD (Mặt trước &amp; sau)"
                        android:textColor="#555555"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>
                    <LinearLayout
                        android:id="@+id/layoutChonAnhCccd"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="12dp">
                        <RelativeLayout
                            android:id="@+id/btnChonAnhTruoc"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:background="@android:drawable/editbox_background_normal">
                            <ImageView
                                android:id="@+id/imgFormAnhTruoc"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerInside"
                                android:src="@android:drawable/ic_menu_camera"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentBottom="true"
                                android:layout_centerHorizontal="true"
                                android:text="Mặt trước"
                                android:textSize="10sp"
                                android:layout_marginBottom="4dp"/>
                        </RelativeLayout>
                        <RelativeLayout
                            android:id="@+id/btnChonAnhSau"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:background="@android:drawable/editbox_background_normal">
                            <ImageView
                                android:id="@+id/imgFormAnhSau"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerInside"
                                android:src="@android:drawable/ic_menu_camera"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentBottom="true"
                                android:layout_centerHorizontal="true"
                                android:text="Mặt sau"
                                android:textSize="10sp"
                                android:layout_marginBottom="4dp"/>
                        </RelativeLayout>
                    </LinearLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">

                        <Button android:id="@+id/btnFormXoaKhach" android:layout_width="wrap_content" android:layout_height="44dp" android:backgroundTint="@android:color/transparent" android:text="Xóa" android:textColor="#E74C3C" android:textStyle="bold" android:textAllCaps="false" android:visibility="gone"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:orientation="horizontal">
                            <Button android:id="@+id/btnFormHuyKhach" android:layout_width="wrap_content" android:layout_height="44dp" android:backgroundTint="@android:color/transparent" android:text="Hủy" android:textColor="#555555" android:layout_marginEnd="8dp" android:textAllCaps="false"/>
                            <Button android:id="@+id/btnFormLuuKhach" android:layout_width="wrap_content" android:layout_height="44dp" android:backgroundTint="#2196F3" android:text="Cập nhật" android:textColor="@android:color/white" android:textStyle="bold" android:textAllCaps="false"/>
                        </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </RelativeLayout>

    <include layout="@layout/toolbar_va_menu"/>

</androidx.drawerlayout.widget.DrawerLayout>