<?xml version="1.0" encoding="utf-8"?>

<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Toolbar -->
        <RelativeLayout
            android:id="@+id/layoutToolbar"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="#FFFFFF"
            android:paddingTop="35dp"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/imgMenu"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:contentDescription="Menu"
                app:tint="#0066B2"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Quản Lý Dịch Vụ"
                android:textColor="#0066B2"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </RelativeLayout>

        <!-- Header -->
        <RelativeLayout
            android:id="@+id/layoutHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/layoutToolbar"
            android:layout_margin="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quản lý dịch vụ"
                android:textColor="#111111"
                android:textSize="24sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:id="@+id/btnThemDichVu"
                android:layout_width="180dp"
                android:layout_height="56dp"
                android:layout_alignParentEnd="true"
                android:background="@android:drawable/toast_frame"
                android:backgroundTint="#2196F3"
                android:gravity="center"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_add"
                    app:tint="@android:color/white"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Thêm dịch vụ"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"/>
            </LinearLayout>

        </RelativeLayout>

        <!-- Search -->
        <LinearLayout
            android:id="@+id/layoutSearch"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_below="@id/layoutHeader"
            android:layout_marginHorizontal="16dp"
            android:background="@android:drawable/editbox_background_normal"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_search"/>

            <EditText
                android:id="@+id/edtTimKiemDichVu"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@android:color/transparent"
                android:hint="Tìm kiếm dịch vụ..."
                android:minHeight="48dp"
                android:paddingVertical="12dp"
                android:importantForAutofill="no"/>
        </LinearLayout>

        <!-- Danh sách dịch vụ -->
        <ListView
            android:id="@+id/lvDichVu"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/layoutSearch"
            android:layout_margin="16dp"
            android:dividerHeight="4dp"/>

        <!-- Form thêm/sửa -->
        <LinearLayout
            android:id="@+id/layoutFormDichVu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_margin="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:elevation="20dp"
            android:orientation="vertical"
            android:visibility="gone">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="#F5F5F5"
                android:paddingHorizontal="16dp">

                <TextView
                    android:id="@+id/txtTieuDeFormDichVu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Thông tin dịch vụ"
                    android:textColor="#0066B2"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <ImageView
                    android:id="@+id/imgDongFormDichVu"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"/>
            </RelativeLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tên dịch vụ"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/edtTenDichVu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:inputType="text"
                        android:importantForAutofill="no"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Đơn giá"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/edtDonGia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:inputType="numberDecimal"
                        android:importantForAutofill="no"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Đơn vị tính"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/edtDonViTinh"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:inputType="text"
                        android:hint="kWh, m3, tháng..."
                        android:importantForAutofill="no"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Ghi chú"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/edtGhiChu"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:gravity="top"
                        android:inputType="textMultiLine"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp">

                        <Button
                            android:id="@+id/btnFormXoaDichVu"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="Xóa"
                            android:textColor="#E74C3C"
                            android:visibility="gone"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true">

                            <Button
                                android:id="@+id/btnFormHuyDichVu"
                                android:layout_width="wrap_content"
                                android:layout_height="44dp"
                                android:text="Hủy"/>

                            <Button
                                android:id="@+id/btnFormLuuDichVu"
                                android:layout_width="wrap_content"
                                android:layout_height="44dp"
                                android:text="Lưu"/>
                        </LinearLayout>

                    </RelativeLayout>

                </LinearLayout>
            </ScrollView>

        </LinearLayout>

    </RelativeLayout>

    <include layout="@layout/toolbar_va_menu"/>

</androidx.drawerlayout.widget.DrawerLayout>
